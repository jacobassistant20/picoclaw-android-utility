<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PicoClaw Utility"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"/>

    <!-- Service Status Card -->
    <LinearLayout
        android:id="@+id/serviceStatusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E8E8E8"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Checking..."
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:textColor="@android:color/holo_blue_dark"/>

        <Button
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

    <!-- Setup Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Setup"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/enableServiceButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Accessibility Service"
        android:layout_marginBottom="24dp"/>

    <!-- Developer Tools -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Developer Tools"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/inspectElementsButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Inspect Screen"
            android:layout_marginEnd="8dp"
            android:enabled="false"/>

        <Button
            android:id="@+id/testActionsButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Test Actions"
            android:layout_marginStart="8dp"
            android:enabled="false"/>

    </LinearLayout>

    <!-- Screen Stream Section (v1.1.0) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/screenStreamCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:strokeColor="@android:color/holo_blue_dark"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Screen Stream (v1.1.0)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:textColor="@android:color/holo_blue_dark"/>

            <TextView
                android:id="@+id/screenStreamStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Requires ScreenStream app"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"
                android:textColor="@android:color/darker_gray"/>

            <Button
                android:id="@+id/openScreenStreamButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open ScreenStream App"
                android:textSize="12sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Install ScreenStream from F-Droid\n2. Enable Local mode, Port 8080\n3. Start streaming\n4. Use WS commands to capture"
                android:textSize="11sp"
                android:layout_marginTop="8dp"
                android:textColor="@android:color/darker_gray"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Piper TTS Section (v1.1.1) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/piperTtsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:strokeColor="@android:color/holo_green_dark"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Piper TTS (v1.1.1)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:textColor="@android:color/holo_green_dark"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Offline text-to-speech using Piper neural TTS. Works without internet."
                android:textSize="12sp"
                android:layout_marginBottom="12dp"
                android:textColor="@android:color/darker_gray"/>

            <Button
                android:id="@+id/piperTtsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Test Piper TTS"
                android:textSize="12sp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Features Info -->
    <TextView
        android:id="@+id/featuresInfoText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Features will appear here..."
        android:textSize="14sp"
        android:textColor="@android:color/holo_blue_dark"
        android:lineSpacingMultiplier="1.2"
        android:padding="8dp"
        android:background="#F5F5F5"/>

    <!-- Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PicoClaw uses Android Accessibility Services to control your device remotely. This is the same mechanism used by TeamViewer, Remote Support apps, and automation tools. No ADB or root required."
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.2"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>